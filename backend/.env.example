# Copy to .env and fill in. The app runs fully without any keys (degrade paths),
# but LLM paraphrasing, self-care drafting, and OCR need these to be non-degraded.

# Leave as SQLite for zero-config local dev; swap for a Postgres+pgvector DSN in prod:
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/hospital_prep
DATABASE_URL=sqlite:///./hospital_prep.db

REDIS_URL=redis://localhost:6379/0

GROQ_API_KEY=
GEMINI_API_KEY=

CELERY_BEAT_INTERVAL_SECONDS=45
QUEUE_AGING_RATE=1.0
QUEUE_AUTO_ESCALATE_MINUTES=45
SELF_CARE_APPROVAL_WINDOW_HOURS=24
ICD10_SIMILARITY_THRESHOLD=0.75
