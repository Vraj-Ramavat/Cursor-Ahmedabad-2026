{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Triage Rule File",
  "type": "object",
  "required": ["version", "severity_order", "rules"],
  "additionalProperties": true,
  "properties": {
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "description": { "type": "string" },
    "severity_order": {
      "type": "array",
      "items": { "type": "string", "enum": ["green", "amber", "red"] },
      "minItems": 3
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "severity", "match"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "severity": { "type": "string", "enum": ["green", "amber", "red"] },
          "description": { "type": "string" },
          "match": {
            "type": "object",
            "additionalProperties": false,
            "required": ["any_keywords"],
            "properties": {
              "any_keywords": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 },
                "minItems": 1
              },
              "with_any_keywords": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    }
  }
}
